{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "JPS: Create preview environment",
      "type": "shell",
      "command": "python3",
      "args": [
        "-m",
        "venv",
        "${workspaceFolder}/.venv"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "JPS: Install preview dependencies",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "pip",
        "install",
        "--disable-pip-version-check",
        "-r",
        "${workspaceFolder}/requirements-dev.txt"
      ],
      "dependsOn": "JPS: Create preview environment",
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "JPS: Build site",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "${workspaceFolder}/web/build.py"
      ],
      "dependsOn": "JPS: Install preview dependencies",
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "JPS: Preview site",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "http.server",
        "8000",
        "--bind",
        "127.0.0.1",
        "--directory",
        "${workspaceFolder}/public"
      ],
      "dependsOn": "JPS: Build site",
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      },
      "runOptions": {
        "instanceLimit": 1
      }
    }
  ]
}
